      "type": "text",
      "x": 22.36904761904748,
      "y": 947.4880952380953,
      "width": 372.8636474609375,
      "height": 360,
      "angle": 0,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
