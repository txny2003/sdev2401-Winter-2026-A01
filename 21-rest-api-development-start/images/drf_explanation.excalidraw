      "seed": 426163288,
      "version": 72,
      "versionNonce": 924769064,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772643468943,
      "link": null,
      "locked": false,
      "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <title>Document</title>\n</head>\n<body>\n\n{% for course in courses %}\n    <li>\n      <h2>{{ course.name }}</h2>\n      <p>Instructor: {{ course.instructor }}</p>\n      <p>Active: {{ course.is_active }}</p>\n      <p>Created: {{ course.created_at }}</p>\n    </li>\n  {% empty %}\n    <li>No courses available.</li>\n  {% endfor %}</body>\n</html>",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <title>Document</title>\n</head>\n<body>\n\n{% for course in courses %}\n    <li>\n      <h2>{{ course.name }}</h2>\n      <p>Instructor: {{ course.instructor }}</p>\n      <p>Active: {{ course.is_active }}</p>\n      <p>Created: {{ course.created_at }}</p>\n    </li>\n  {% empty %}\n    <li>No courses available.</li>\n  {% endfor %}</body>\n</html>",
      "autoResize": true,
      "lineHeight": 1.25
    },
